# ── WhatsApp alerts (free via CallMeBot) ─────────────────────────────────────
# 1. Save +34 644 59 73 97 in your WhatsApp contacts
# 2. Send: I allow callmebot to send me messages
# 3. You'll receive your API key
WHATSAPP_PHONE=91XXXXXXXXXX        # your number with country code, no +
WHATSAPP_APIKEY=1234567

# ── Angel One SmartAPI (real-time data, no 15-min delay) ──────────────────────
