# ANGEL_API_KEY=your_api_key
# ANGEL_CLIENT_ID=A12345           # your Angel One login ID
# ANGEL_MPIN=1234                  # your 4-digit MPIN
# ANGEL_TOTP_SECRET=BASE32SECRET   # from Google Authenticator QR code setup
